rules_version = '2';

// =============================================================================
// Firestore Security Rules for Kigali City Services & Places Directory
// =============================================================================
//
// Collections:
//   - users/{userId}     → User profiles
//   - listings/{listingId} → Service/place listings
//
// Rules:
//   - Users can only read/write their own profile
//   - Any authenticated user can read all listings
//   - Any authenticated user can create listings
//   - Only the listing creator can update or delete their own listings

service cloud.firestore {
  match /databases/{database}/documents {

    // ── User Profiles ──────────────────────────────────────────────────────
    match /users/{userId} {
      // Users can read and write only their own profile
      allow read, write: if request.auth != null && request.auth.uid == userId;
    }

    // ── Listings ───────────────────────────────────────────────────────────
    match /listings/{listingId} {
      // Any authenticated user can read all listings
      allow read: if request.auth != null;

      // Any authenticated user can create a listing
      // The createdBy field must match the authenticated user's UID
      allow create: if request.auth != null
                    && request.resource.data.createdBy == request.auth.uid;

      // Only the creator can update their own listings
      allow update: if request.auth != null
                    && resource.data.createdBy == request.auth.uid;

      // Only the creator can delete their own listings
      allow delete: if request.auth != null
                    && resource.data.createdBy == request.auth.uid;
    }
  }
}
